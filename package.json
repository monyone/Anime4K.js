{
  "name": "anime4k.js",
  "version": "1.1.2",
  "description": "Anime4K WebGL port/implementation",
  "keywords": [
    "anime4k",
    "webgl",
    "glsl",
    "upscale",
    "upscaler",
    "image",
    "video"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/monyone/Anime4K.js"
  },
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./shaders": {
      "import": {
        "types": "./dist/shaders.d.mts",
        "default": "./dist/shaders.mjs"
      },
      "require": {
        "types": "./dist/shaders.d.cts",
        "default": "./dist/shaders.cjs"
      }
    },
    "./upscaler": {
      "import": {
        "types": "./dist/upscaler.d.mts",
        "default": "./dist/upscaler.mjs"
      },
      "require": {
        "types": "./dist/upscaler.d.cts",
        "default": "./dist/upscaler.cjs"
      }
    },
    "./dist/anime4k.js": "./dist/anime4k.js"
  },
  "files": [
    "dist/**/*",
    "src/**/*",
    "tsconfig.json"
  ],
  "license": "MIT",
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "rimraf dist",
    "build": "NODE_ENV=production tsdown",
    "prepublishOnly": "yarn build",
    "tsc": "tsc --noEmit"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  }
}
